RewriteEngine On
RewriteBase /ADVANCE/

# 1. FORZAR LA QUITA DE .PHP (Redirección externa)
# Si el usuario hace clic en un enlace con .php, se lo quitamos visualmente

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. LEER EL ARCHIVO INTERNAMENTE (Redirección interna)
# El servidor busca el archivo .php por detrás, pero mantiene la URL limpia

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [NC,L]